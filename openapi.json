{
  "openapi": "3.1.0",
  "info": {
    "title": "wcfLink API",
    "description": "wcfLink 微信消息转发服务接口文档",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://127.0.0.1:17890", "description": "本地开发环境" }
  ],
  "tags": [
    { "name": "健康检查", "description": "服务健康状态探针" },
    { "name": "版本", "description": "版本信息" },
    { "name": "账号", "description": "账号管理与登录" },
    { "name": "消息", "description": "消息发送" },
    { "name": "事件", "description": "收发消息事件流" },
    { "name": "日志", "description": "运行日志查询" },
    { "name": "设置", "description": "系统设置" }
  ],
  "paths": {
    "/health/live": {
      "get": {
        "tags": ["健康检查"], "summary": "存活探针", "description": "检查服务进程是否存活", "operationId": "healthLive",
        "responses": { "200": { "description": "服务存活", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } } } }
      }
    },
    "/health/ready": {
      "get": {
        "tags": ["健康检查"], "summary": "就绪探针", "description": "检查服务是否就绪可接受请求", "operationId": "healthReady",
        "responses": { "200": { "description": "服务就绪", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/HealthResponse" } } } } }
      }
    },
    "/api/version": {
      "get": {
        "tags": ["版本"], "summary": "获取版本信息", "description": "返回服务版本号、commit hash 和构建时间", "operationId": "getVersion",
        "responses": { "200": { "description": "版本信息", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VersionInfo" } } } } }
      }
    },
    "/api/accounts": {
      "get": {
        "tags": ["账号"], "summary": "获取账号列表", "description": "返回所有已登录的微信账号及其状态", "operationId": "listAccounts",
        "responses": { "200": { "description": "账号列表", "content": { "application/json": { "schema": { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Account" } } } } } } } }
      }
    },
    "/api/accounts/login/start": {
      "post": {
        "tags": ["账号"], "summary": "发起登录", "description": "发起一个新的微信扫码登录会话，返回 session_id 用于后续轮询登录状态和获取二维码", "operationId": "startLogin",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "base_url": { "type": "string", "description": "iLink 服务地址，留空使用默认值" } } } } } },
        "responses": { "200": { "description": "登录会话已创建", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginSession" } } } } }
      }
    },
    "/api/accounts/login/status": {
      "get": {
        "tags": ["账号"], "summary": "查询登录状态", "description": "根据 session_id 轮询登录会话的当前状态（等待扫码/已扫码/已确认/失败）", "operationId": "getLoginStatus",
        "parameters": [{ "name": "session_id", "in": "query", "required": true, "description": "登录会话 ID，由 /api/accounts/login/start 返回", "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "登录状态", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginSession" } } } },
          "400": { "description": "缺少 session_id 参数", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/accounts/login/qr": {
      "get": {
        "tags": ["账号"], "summary": "获取登录二维码图片", "description": "根据 session_id 返回 PNG 格式的登录二维码图片，用于用户扫码", "operationId": "getLoginQR",
        "parameters": [{ "name": "session_id", "in": "query", "required": true, "description": "登录会话 ID", "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "二维码 PNG 图片", "content": { "image/png": { "schema": { "type": "string", "format": "binary" } } } },
          "400": { "description": "二维码 URL 为空或参数缺失", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/events": {
      "get": {
        "tags": ["事件"], "summary": "获取事件列表", "description": "分页获取收发消息事件，支持增量拉取。通过 after_id 传入上次拉取的最大 id 实现增量轮询", "operationId": "listEvents",
        "parameters": [
          { "name": "after_id", "in": "query", "required": false, "description": "只返回 id 大于此值的事件，用于增量拉取，默认 0", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "required": false, "description": "单次返回最大条数，默认 100", "schema": { "type": "integer", "default": 100 } }
        ],
        "responses": { "200": { "description": "事件列表", "content": { "application/json": { "schema": { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/Event" } } } } } } } }
      }
    },
    "/api/logs": {
      "get": {
        "tags": ["日志"], "summary": "获取运行日志", "description": "分页获取服务运行日志，支持增量拉取", "operationId": "listLogs",
        "parameters": [
          { "name": "after_id", "in": "query", "required": false, "description": "只返回 id 大于此值的日志，默认 0", "schema": { "type": "integer", "default": 0 } },
          { "name": "limit", "in": "query", "required": false, "description": "单次返回最大条数，默认 100", "schema": { "type": "integer", "default": 100 } }
        ],
        "responses": { "200": { "description": "日志列表", "content": { "application/json": { "schema": { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/LogEntry" } } } } } } } }
      }
    },
    "/api/settings": {
      "get": {
        "tags": ["设置"], "summary": "获取当前设置", "description": "返回当前系统设置，包括监听地址和 webhook 回调地址", "operationId": "getSettings",
        "responses": { "200": { "description": "当前设置", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Settings" } } } } }
      },
      "post": {
        "tags": ["设置"], "summary": "更新设置", "description": "更新系统设置。修改 listen_addr 后需要重启服务才能生效", "operationId": "updateSettings",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Settings" } } } },
        "responses": { "200": { "description": "更新成功", "content": { "application/json": { "schema": { "type": "object", "properties": { "settings": { "$ref": "#/components/schemas/Settings" }, "restart_needed": { "type": "boolean", "description": "是否需要重启服务" } } } } } },
          "400": { "description": "参数校验失败（如 listen_addr 为空）", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } } }
      }
    },
    "/api/messages/send-text": {
      "post": {
        "tags": ["消息"], "summary": "发送文本消息", "description": "通过指定账号向目标用户发送文本消息", "operationId": "sendText",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["account_id", "to_user_id", "text"], "properties": {
          "account_id": { "type": "string", "description": "发送方账号 ID" },
          "to_user_id": { "type": "string", "description": "接收方用户 ID" },
          "text": { "type": "string", "description": "消息文本内容" },
          "context_token": { "type": "string", "description": "上下文 token，用于关联会话，可选" }
        } } } } },
        "responses": {
          "200": { "description": "发送成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OkResponse" } } } },
          "400": { "description": "参数错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "账号不存在", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    },
    "/api/messages/send-media": {
      "post": {
        "tags": ["消息"], "summary": "发送媒体消息", "description": "通过指定账号向目标用户发送图片、视频、文件等媒体消息", "operationId": "sendMedia",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["account_id", "to_user_id", "type", "file_path"], "properties": {
          "account_id": { "type": "string", "description": "发送方账号 ID" },
          "to_user_id": { "type": "string", "description": "接收方用户 ID" },
          "type": { "type": "string", "description": "媒体类型，如 image、video、file 等" },
          "file_path": { "type": "string", "description": "媒体文件路径" },
          "text": { "type": "string", "description": "附带的文本说明，可选" },
          "context_token": { "type": "string", "description": "上下文 token，可选" }
        } } } } },
        "responses": {
          "200": { "description": "发送成功", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OkResponse" } } } },
          "400": { "description": "参数错误", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } },
          "404": { "description": "账号不存在", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "description": "是否健康" },
          "timestamp": { "type": "string", "format": "date-time", "description": "当前服务器时间 (UTC ISO8601)" },
          "version": { "$ref": "#/components/schemas/VersionInfo" }
        }
      },
      "VersionInfo": {
        "type": "object",
        "properties": {
          "version": { "type": "string", "description": "语义化版本号" },
          "commit": { "type": "string", "nullable": true, "description": "Git commit hash" },
          "build_time": { "type": "string", "nullable": true, "description": "构建时间" },
          "modified": { "type": "boolean", "description": "是否有未提交的修改" }
        }
      },
      "LoginSession": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string", "description": "登录会话唯一 ID" },
          "base_url": { "type": "string", "description": "iLink 服务地址" },
          "qr_code_url": { "type": "string", "description": "二维码内容 URL" },
          "status": { "type": "string", "description": "登录状态：pending / scanned / confirmed / failed" },
          "account_id": { "type": "string", "description": "登录成功后的账号 ID" },
          "ilink_user_id": { "type": "string", "description": "iLink 用户 ID" },
          "error": { "type": "string", "description": "错误信息（失败时）" },
          "started_at": { "type": "string", "format": "date-time", "description": "会话创建时间" },
          "updated_at": { "type": "string", "format": "date-time", "description": "最后更新时间" },
          "completed_at": { "type": "string", "format": "date-time", "description": "完成时间" }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "account_id": { "type": "string", "description": "账号唯一 ID" },
          "base_url": { "type": "string", "description": "iLink 服务地址" },
          "ilink_user_id": { "type": "string", "description": "iLink 用户 ID" },
          "enabled": { "type": "boolean", "description": "是否启用消息轮询" },
          "login_status": { "type": "string", "description": "登录状态" },
          "last_error": { "type": "string", "description": "最近一次错误信息" },
          "last_poll_at": { "type": "string", "format": "date-time", "description": "最后一次轮询时间" },
          "last_inbound_at": { "type": "string", "format": "date-time", "description": "最后一次收到消息时间" },
          "created_at": { "type": "string", "format": "date-time", "description": "创建时间" },
          "updated_at": { "type": "string", "format": "date-time", "description": "更新时间" }
        }
      },
      "Event": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "事件自增 ID，用于增量拉取" },
          "account_id": { "type": "string", "description": "关联账号 ID" },
          "direction": { "type": "string", "description": "方向：inbound（收到）/ outbound（发出）" },
          "event_type": { "type": "string", "description": "事件类型，如 text、image、video 等" },
          "from_user_id": { "type": "string", "description": "发送方用户 ID" },
          "to_user_id": { "type": "string", "description": "接收方用户 ID" },
          "message_id": { "type": "integer", "description": "消息 ID" },
          "context_token": { "type": "string", "description": "上下文 token" },
          "body_text": { "type": "string", "description": "文本内容" },
          "media_path": { "type": "string", "description": "媒体文件路径" },
          "media_file_name": { "type": "string", "description": "媒体文件名" },
          "media_mime_type": { "type": "string", "description": "媒体 MIME 类型" },
          "raw_json": { "type": "string", "description": "原始 JSON 数据" },
          "created_at": { "type": "string", "format": "date-time", "description": "事件创建时间" }
        }
      },
      "LogEntry": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "description": "日志自增 ID" },
          "level": { "type": "string", "description": "日志级别：DEBUG / INFO / WARNING / ERROR" },
          "message": { "type": "string", "description": "日志内容" },
          "source": { "type": "string", "description": "日志来源模块" },
          "meta_json": { "type": "string", "description": "附加元数据 JSON" },
          "created_at": { "type": "string", "format": "date-time", "description": "记录时间" }
        }
      },
      "Settings": {
        "type": "object",
        "required": ["listen_addr"],
        "properties": {
          "listen_addr": { "type": "string", "description": "HTTP 服务监听地址，格式 host:port，如 0.0.0.0:17890" },
          "webhook_url": { "type": "string", "description": "Webhook 回调地址，收到消息时会 POST 到此 URL" }
        }
      },
      "OkResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean", "description": "操作是否成功" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "description": "错误描述信息" }
        }
      }
    }
  }
}
